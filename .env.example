# Copie este arquivo para .env e preencha suas chaves

# Google Vision API - para OCR real
# Obtenha em: https://console.cloud.google.com/apis/library/vision.googleapis.com
EXPO_PUBLIC_GOOGLE_VISION_KEY=

# Google Drive API - para backup na nuvem
# Obtenha em: https://console.cloud.google.com/apis/library/drive.googleapis.com
EXPO_PUBLIC_GOOGLE_DRIVE_KEY=
